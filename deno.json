        "tidewave": "npm:tidewave@^0.7.0",
        "vite": "npm:vite@^8.1.3",
        "esbuild": "npm:esbuild@^0.28.1",
        "codemirror": "npm:codemirror@^6.0.2",
        "@codemirror/lang-markdown": "npm:@codemirror/lang-markdown@^6.5.0",
        "@codemirror/lang-javascript": "npm:@codemirror/lang-javascript@^6.2.5",
        "@codemirror/lang-json": "npm:@codemirror/lang-json@^6.0.2",
        "@codemirror/lang-python": "npm:@codemirror/lang-python@^6.2.1",
        "@codemirror/lang-yaml": "npm:@codemirror/lang-yaml@^6.1.3",
        "@codemirror/language": "npm:@codemirror/language@^6.12.4",
        "@codemirror/legacy-modes": "npm:@codemirror/legacy-modes@^6.5.3",
        "@codemirror/state": "npm:@codemirror/state@^6.7.1",
        "@codemirror/view": "npm:@codemirror/view@^6.43.6",
        "@lezer/common": "npm:@lezer/common@^1.5.2",
        "@lezer/highlight": "npm:@lezer/highlight@^1.2.3",
        "@pierre/diffs/worker/worker.js": "./src/ui/workspace/react/pierre-diffs-worker-shim.js",
        "@pierre/diffs/react": "npm:@pierre/diffs@1.2.8/react",
        "@pierre/diffs": "npm:@pierre/diffs@1.2.8",
        "@radix-ui/react-checkbox": "npm:@radix-ui/react-checkbox@^1.3.3",
        "@radix-ui/react-collapsible": "npm:@radix-ui/react-collapsible@^1.1.12",
        "@radix-ui/react-context-menu": "npm:@radix-ui/react-context-menu@^2.2.15",
        "@radix-ui/react-dialog": "npm:@radix-ui/react-dialog@^1.1.19",
        "@radix-ui/react-dropdown-menu": "npm:@radix-ui/react-dropdown-menu@^2.1.20",
        "@radix-ui/react-popover": "npm:@radix-ui/react-popover@^1.1.19",
        "@radix-ui/react-slot": "npm:@radix-ui/react-slot@^1.3.0",
        "@radix-ui/react-tabs": "npm:@radix-ui/react-tabs@^1.1.17",
        "@radix-ui/react-tooltip": "npm:@radix-ui/react-tooltip@^1.2.12",
        "@tanstack/react-table": "npm:@tanstack/react-table@^8.21.3",
        "@viz-js/viz": "npm:@viz-js/viz@^3.28.0",
        "class-variance-authority": "npm:class-variance-authority@^0.7.1",
        "clsx": "npm:clsx@^2.1.1",
        "diff": "npm:diff@^8.0.4",
        "dompurify": "npm:dompurify@^3.4.11",
        "highlight.js": "npm:highlight.js@^11.11.1",
        "katex": "npm:katex@^0.16.47",
        "lucide-react": "npm:lucide-react@^1.23.0",
        "marked": "npm:marked@^17.0.6",
        "mermaid": "npm:mermaid@^11.16.0",
        "motion": "npm:motion@^12.42.2",
        "tailwind-merge": "npm:tailwind-merge@^3.6.0",
        "unique-username-generator": "npm:unique-username-generator@^1.5.1",
        "fuse.js": "npm:fuse.js@^7.4.2",
        "perfect-freehand": "npm:perfect-freehand@^1.2.2",
        "@deno/astro-adapter": "npm:@deno/astro-adapter@^0.3.2",
        "@astrojs/react": "npm:@astrojs/react@^4.3.1",
        "@astrojs/check": "npm:@astrojs/check@^0.9.9",
        "astro": "npm:astro@^5.13.11",
        "typescript": "npm:typescript@^5.9.3",
        "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^4.7.0",
        "react/jsx-runtime": "npm:react@^19.2.7/jsx-runtime",
        "react/jsx-dev-runtime": "npm:react@^19.2.7/jsx-dev-runtime"
    },
    "tasks": {
        "ci": "deno task -q check && deno task -q workspace:check && deno task -q lint && deno task -q fmt:check && deno task -q test",
        "cli": "deno run -A src/cli.js",
        "test": "deno run -A scripts/write-version.js && snip run -- deno test -A",
        "lint": "snip run -- deno lint",
        "fmt:check": "snip run -- deno fmt --check",
        "githooks:install": "git config core.hooksPath .githooks",
        "githooks:uninstall": "git config --unset core.hooksPath",
        "check": "deno run -A scripts/write-version.js && snip run -- deno check --doc src/**/*.js src/**/*.jsx",
        "workspace:dev": "deno run -A --env npm:astro dev --config src/ui/workspace/astro.config.mjs --host 127.0.0.1 --port 5173",
        "workspace:react:check": "deno task workspace:check",
        "workspace:test": "deno test -A src/ui/workspace src/cmd/plans/ui.test.js",
        "compile": "deno run -A ./scripts/compile.js",
        "prototype:plan-ui": "deno task -c prototypes/fresh-plan-ui/deno.json dev",
        "workspace:dev:plan-review": "deno run -A --env npm:astro dev --config src/ui/workspace/astro.config.mjs --host 127.0.0.1 --port 5173 --open /dev/plan-review",
        "workspace:dev:code-review": "deno run -A --env npm:astro dev --config src/ui/workspace/astro.config.mjs --host 127.0.0.1 --port 5173 --open /dev/code-review",
        "workspace:build": "deno run -A --env npm:astro build --config src/ui/workspace/astro.config.mjs",
        "workspace:check": "deno run -A --env npm:astro check --root src/ui/workspace --tsconfig tsconfig.json"
    },
    "fmt": {
        "lineWidth": 120,
        "indentWidth": 4
    },
    "exclude": [
        "node_modules",
        ".idea",
        ".history",
        "third_party",
        "_fresh",
        ".astro",
        "dist",
        "src/ui/workspace/node_modules",
        "src/ui/workspace/.astro"
    ]
}
