{
    "compilerOptions": {
        "checkJs": true
    },
    "imports": {
        "chalk": "npm:chalk@^5.6.2",
        "@earendil-works/pi-tui": "npm:@earendil-works/pi-tui@^0.79.9",
        "@earendil-works/pi-ai": "npm:@earendil-works/pi-ai@^0.79.9",
        "@earendil-works/pi-coding-agent": "npm:@earendil-works/pi-coding-agent@^0.79.4",
        "@earendil-works/pi-agent-core": "npm:@earendil-works/pi-agent-core@^0.79.5",
        "@sinclair/typebox": "npm:@sinclair/typebox@^0.34.49",
        "@std/front-matter": "jsr:@std/front-matter@^1.0.9",
        "@std/path": "jsr:@std/path@^1.1.5",
        "@std/assert": "jsr:@std/assert@^1.0.19",
        "@std/jsonc": "jsr:@std/jsonc@^1.0.2",
        "@std/cli/parse-args": "jsr:@std/cli@^1.0.30/parse-args",
        "@gandazgul/plannotator-pi-extension-compiled": "npm:@gandazgul/plannotator-pi-extension-compiled@^0.21.1",
        "@gandazgul/plannotator-pi-extension-compiled/server": "npm:@gandazgul/plannotator-pi-extension-compiled@^0.21.1/server",
        "@gandazgul/plannotator-pi-extension-compiled/assets": "npm:@gandazgul/plannotator-pi-extension-compiled@^0.21.1/assets",
        "strip-ansi": "npm:strip-ansi@^7.2.0",
        "quikdown/ast": "npm:quikdown@^1.2.12/ast",
        "proper-lockfile": "npm:proper-lockfile@^4.1.2"
    },
    "tasks": {
        "ci": "deno task -q check && deno task -q lint && deno task -q fmt:check && deno task -q test",
        "cli": "deno run -A src/cli.js",
        "test": "snip run -- deno test -A",
        "lint": "snip run -- deno lint",
        "fmt:check": "snip run -- deno fmt --check",
        "check": "snip run -- deno check --doc src/**/*.js",
        "compile": "deno run -A ./scripts/compile.js",
        "prototype:plan-ui": "deno task -c prototypes/fresh-plan-ui/deno.json dev"
    },
    "fmt": {
        "lineWidth": 120,
        "indentWidth": 4
    },
    "exclude": [
        "node_modules",
        ".idea",
        ".history"
    ]
}
