{
    "compilerOptions": {
        "checkJs": true,
        "jsx": "react-jsx",
        "jsxImportSource": "preact",
        "types": [
            "vite/client"
        ],
        "lib": [
            "deno.ns",
            "dom",
            "dom.iterable",
            "esnext"
        ]
    },
    "nodeModulesDir": "auto",
    "imports": {
        "chalk": "npm:chalk@^5.6.2",
        "@earendil-works/pi-tui": "npm:@earendil-works/pi-tui@^0.80.2",
        "@earendil-works/pi-ai": "npm:@earendil-works/pi-ai@^0.80.2",
        "@earendil-works/pi-coding-agent": "npm:@earendil-works/pi-coding-agent@^0.80.3",
        "@earendil-works/pi-agent-core": "npm:@earendil-works/pi-agent-core@^0.80.2",
        "@sinclair/typebox": "npm:@sinclair/typebox@^0.34.49",
        "@std/front-matter": "jsr:@std/front-matter@^1.0.9",
        "@std/path": "jsr:@std/path@^1.1.6",
        "@std/assert": "jsr:@std/assert@^1.0.19",
        "@std/jsonc": "jsr:@std/jsonc@^1.0.2",
        "@std/cli/parse-args": "jsr:@std/cli@^1.0.30/parse-args",
        "@gandazgul/plannotator-pi-extension-compiled": "npm:@gandazgul/plannotator-pi-extension-compiled@^0.22.0",
        "@gandazgul/plannotator-pi-extension-compiled/server": "npm:@gandazgul/plannotator-pi-extension-compiled@^0.22.0/server",
        "@gandazgul/plannotator-pi-extension-compiled/assets": "npm:@gandazgul/plannotator-pi-extension-compiled@^0.22.0/assets",
        "@plannotator/ui/": "./third_party/plannotator/packages/ui/",
        "@plannotator/shared/": "./third_party/plannotator/packages/shared/",
        "@plannotator/ai/": "./third_party/plannotator/packages/ai/",
        "strip-ansi": "npm:strip-ansi@^7.2.0",
        "quikdown": "npm:quikdown@^1.2.21",
        "quikdown/ast": "npm:quikdown@^1.2.21/ast",
        "proper-lockfile": "npm:proper-lockfile@^4.1.2",
        "fresh": "jsr:@fresh/core@^2.3.3",
        "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
        "preact": "npm:preact@^10.29.4",
        "preact/jsx-runtime": "npm:preact@^10.29.4/jsx-runtime",
        "preact/jsx-dev-runtime": "npm:preact@^10.29.4/jsx-dev-runtime",
        "@preact/signals": "npm:@preact/signals@^2.9.2",
        "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.18",
        "tailwindcss": "npm:tailwindcss@^4.1.18",
        "react": "npm:react@^19.2.3",
        "react-dom": "npm:react-dom@^19.2.3",
        "react-dom/client": "npm:react-dom@^19.2.3/client",
        "@types/react": "npm:@types/react@^19.2.0",
        "@types/react-dom": "npm:@types/react-dom@^19.2.0",
        "@zag-js/dialog": "npm:@zag-js/dialog@^1.31.1",
        "@zag-js/preact": "npm:@zag-js/preact@^1.31.1",
        "tidewave": "npm:tidewave@^0.7.0",
        "vite": "npm:vite@^8.1.3",
        "esbuild": "npm:esbuild@^0.28.1",
        "unocss": "npm:unocss@^66.5.9",
        "codemirror": "npm:codemirror@^6.0.2",
        "@codemirror/lang-markdown": "npm:@codemirror/lang-markdown@^6.5.0",
        "@codemirror/lang-javascript": "npm:@codemirror/lang-javascript@^6.2.5",
        "@codemirror/lang-json": "npm:@codemirror/lang-json@^6.0.2",
        "@codemirror/lang-python": "npm:@codemirror/lang-python@^6.2.1",
        "@codemirror/lang-yaml": "npm:@codemirror/lang-yaml@^6.1.3",
        "@codemirror/language": "npm:@codemirror/language@^6.12.3",
        "@codemirror/legacy-modes": "npm:@codemirror/legacy-modes@^6.5.3",
        "@codemirror/state": "npm:@codemirror/state@^6.6.0",
        "@codemirror/view": "npm:@codemirror/view@^6.43.0",
        "@lezer/common": "npm:@lezer/common@^1.5.2",
        "@lezer/highlight": "npm:@lezer/highlight@^1.2.3",
        "@pierre/diffs": "npm:@pierre/diffs@1.2.8",
        "@radix-ui/react-dialog": "npm:@radix-ui/react-dialog@^1.1.15",
        "@radix-ui/react-dropdown-menu": "npm:@radix-ui/react-dropdown-menu@^2.1.16",
        "@radix-ui/react-popover": "npm:@radix-ui/react-popover@^1.1.15",
        "@radix-ui/react-slot": "npm:@radix-ui/react-slot@^1.2.4",
        "@radix-ui/react-tabs": "npm:@radix-ui/react-tabs@^1.1.13",
        "@radix-ui/react-tooltip": "npm:@radix-ui/react-tooltip@^1.2.8",
        "@tanstack/react-table": "npm:@tanstack/react-table@^8.21.3",
        "@viz-js/viz": "npm:@viz-js/viz@^3.25.0",
        "class-variance-authority": "npm:class-variance-authority@^0.7.1",
        "clsx": "npm:clsx@^2.1.1",
        "diff": "npm:diff@^8.0.3",
        "dompurify": "npm:dompurify@^3.3.3",
        "highlight.js": "npm:highlight.js@^11.11.1",
        "katex": "npm:katex@^0.16.47",
        "lucide-react": "npm:lucide-react@^1.14.0",
        "marked": "npm:marked@^17.0.6",
        "mermaid": "npm:mermaid@^11.12.2",
        "motion": "npm:motion@^12.38.0",
        "tailwind-merge": "npm:tailwind-merge@^3.6.0",
        "unique-username-generator": "npm:unique-username-generator@^1.5.1",
        "fuse.js": "npm:fuse.js@^7"
    },
    "tasks": {
        "ci": "deno task -q check && deno task -q workspace:react:check && deno task -q lint && deno task -q fmt:check && deno task -q test",
        "cli": "deno run -A src/cli.js",
        "test": "deno run -A scripts/write-version.js && snip run -- deno test -A",
        "lint": "snip run -- deno lint",
        "fmt:check": "snip run -- deno fmt --check",
        "githooks:install": "git config core.hooksPath .githooks",
        "githooks:uninstall": "git config --unset core.hooksPath",
        "check": "deno run -A scripts/write-version.js && snip run -- deno check --doc src/**/*.js src/**/*.jsx",
        "workspace:dev": "deno run -A npm:vite -c src/ui/workspace/vite.config.js",
        "workspace:react:check": "deno run -A npm:vite -c src/ui/workspace/react/vite.config.js build && rm -rf _fresh/workspace-react-check",
        "workspace:test": "deno test -A src/ui/workspace src/cmd/plans/ui.test.js",
        "compile": "deno run -A ./scripts/compile.js",
        "prototype:plan-ui": "deno task -c prototypes/fresh-plan-ui/deno.json dev"
    },
    "fmt": {
        "lineWidth": 120,
        "indentWidth": 4
    },
    "exclude": [
        "node_modules",
        ".idea",
        ".history",
        "third_party",
        "_fresh"
    ]
}