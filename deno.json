        "proper-lockfile": "npm:proper-lockfile@^4.1.2",
        "preact": "npm:preact@^10.29.7",
        "preact/jsx-runtime": "npm:preact@^10.29.7/jsx-runtime",
        "preact/jsx-dev-runtime": "npm:preact@^10.29.7/jsx-dev-runtime",
        "@preact/signals": "npm:@preact/signals@^2.9.3",
        "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.3.2",
        "tailwindcss": "npm:tailwindcss@^4.3.2",
        "react": "npm:react@^19.2.7",
        "react-dom": "npm:react-dom@^19.2.7",
        "react-dom/client": "npm:react-dom@^19.2.7/client",
