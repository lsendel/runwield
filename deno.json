{
    "compilerOptions": {
        "checkJs": true
    },
    "imports": {
        "chalk": "npm:chalk@^5.4.1",
        "@earendil-works/pi-tui": "npm:@earendil-works/pi-tui@^0.74.0",
        "@earendil-works/pi-ai": "npm:@earendil-works/pi-ai@^0.74.0",
        "@earendil-works/pi-coding-agent": "npm:@earendil-works/pi-coding-agent@^0.74.0",
        "@earendil-works/pi-agent-core": "npm:@earendil-works/pi-agent-core@^0.74.0",
        "@sinclair/typebox": "npm:@sinclair/typebox@^0.34.41",
        "@std/front-matter": "jsr:@std/front-matter@^1.0.0",
        "@std/path": "jsr:@std/path@^1.0.0",
        "@std/assert": "jsr:@std/assert@^1.0.0",
        "@std/cli/parse-args": "jsr:@std/cli@^1.0.0/parse-args",
        "@gandazgul/plannotator-pi-extension-compiled": "npm:@gandazgul/plannotator-pi-extension-compiled@^1.0.2",
        "@gandazgul/plannotator-pi-extension-compiled/server": "npm:@gandazgul/plannotator-pi-extension-compiled@^1.0.2/server",
        "@gandazgul/plannotator-pi-extension-compiled/assets": "npm:@gandazgul/plannotator-pi-extension-compiled@^1.0.2/assets",
        "strip-ansi": "npm:strip-ansi@^7.1.2",
        "quikdown/ast": "npm:quikdown@^1.2.12/ast",
        "proper-lockfile": "npm:proper-lockfile@^3.0.0"
    },
    "tasks": {
        "ci": "deno task check && deno lint && deno fmt --check && deno task test",
        "cli": "deno run -A src/cli.js",
        "test": "deno test -A",
        "check": "deno check --doc src/**/*.js",
        "compile": "deno run -A ./scripts/compile.js"
    },
    "fmt": {
        "lineWidth": 120,
        "indentWidth": 4
    },
    "exclude": [
        "node_modules",
        ".idea",
        ".history"
    ]
}
